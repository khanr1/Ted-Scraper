        <cbc:ProcedureCode listName="procurement-procedure-type">neg-wo-call</cbc:ProcedureCode>
        <cac:ProcessJustification>
            <cbc:ProcessReasonCode listName="direct-award-justification">technical</cbc:ProcessReasonCode>
            <cbc:ProcessReason languageID="DEU">Die besonderen Anforderungen an den
                Vergabegegenstand (1. Tabletop Design/Räumliche Anforderung, 2. Kryo-Performance und
                Verkabelung, 3. Separation Kühlkopf und Experiment / Exzellente Vibrationsisolation,
                4. Schnelle Cooldowns, 5. Zukunfsgewandte Wirtschaftlichkeit) können von nur einem
                Anbieter realisiert werden. Insbesondere ist es momentan bei keinem anderen Anbieter
                möglich, den Cold Head von der Mischeinheit (und Experiment) mehr als 1 m zu
                trennen. Auch die schnelle Abkühlzeit ist schwierig zu erreichen. Kein anderer
                Anbieter kann alle Kriterien zusammen erreichen. Die Direktvergabe an die Qinu GmbH,
                Karlsruhe, ist daher sachlich, technisch und vergaberechtlich begründet.</cbc:ProcessReason>
        </cac:ProcessJustification>
    </cac:TenderingProcess>
