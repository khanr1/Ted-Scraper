<xs:schema xmlns:xs="http://www.w3.org/2001/XMLSchema" xmlns:ns="http://www.w3.org/1999/xlink" targetNamespace="http://www.w3.org/1999/xlink" version="R2.0.8.S02.E01">
	<!--implementation of Simple xlink -->
	<!--Simple link links two locations in one direction, the start of the link is its declaration.-->
	<!-- As the link part is mostly informative, the Schema is kept basic. The commented part contains more advanced linking options-->
	<xs:attribute name="type">
		<xs:simpleType>
			<xs:restriction base="xs:NMTOKEN">
				<xs:enumeration value="simple"/>
			</xs:restriction>
		</xs:simpleType>
	</xs:attribute>
	<xs:attribute name="href" type="xs:anyURI"/>
	<xs:attribute name="title" type="xs:string"/>
