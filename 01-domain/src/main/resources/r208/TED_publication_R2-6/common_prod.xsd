<xs:schema xmlns:xlink="http://www.w3.org/1999/xlink" xmlns:xs="http://www.w3.org/2001/XMLSchema" xmlns:n2021="http://publications.europa.eu/resource/schema/ted/2021/nuts" elementFormDefault="qualified" attributeFormDefault="unqualified" version="R2.0.8.S05.E01">
	<xs:import namespace="http://www.w3.org/1999/xlink" schemaLocation="xlink.xsd"/>
	<xs:import namespace="http://publications.europa.eu/resource/schema/ted/2021/nuts" schemaLocation="nuts_codes_2021.xsd"/>
	<xs:include schemaLocation="common.xsd"/>
	<!--<xs:include schemaLocation="headings.xsd"/>-->
	<!--###### TED EXPORT SCHEMA ######-->
	<!--###### Main Sections ###############-->
	<!-- TECHNICAL_SECTION -->
	<xs:complexType name="t_technical_section">
		<xs:sequence>
			<xs:element name="RECEPTION_ID" type="t_reception_id"/>
			<xs:element ref="DELETION_DATE"/>
			<xs:element name="FORM_LG_LIST" type="xs:string"/>
			<xs:element ref="COMMENTS" minOccurs="0"/>
			<xs:element name="OLD_HEADING" type="xs:string" minOccurs="0"/>
		</xs:sequence>
	</xs:complexType>
	<xs:element name="TECHNICAL_SECTION" type="t_technical_section"/>
	<!-- LINKS_SECTION-->
	<xs:complexType name="t_links_section">
		<xs:sequence>
			<xs:element name="XML_SCHEMA_DEFINITION_LINK" type="all_links" minOccurs="0"/>
			<xs:element name="OFFICIAL_FORMS_LINK" type="all_links" minOccurs="0"/>
			<xs:element name="FORMS_LABELS_LINK" type="all_links" minOccurs="0"/>
			<xs:element name="ORIGINAL_CPV_LINK" type="all_links" minOccurs="0"/>
			<xs:element name="ORIGINAL_NUTS_LINK" type="all_links" minOccurs="0"/>
		</xs:sequence>
	</xs:complexType>
	<xs:element name="LINKS_SECTION" type="t_links_section"/>
	<xs:complexType name="all_links">
		<xs:attribute ref="xlink:type" use="required"/>
		<xs:attribute ref="xlink:href" use="required"/>
		<xs:attribute ref="xlink:title"/>
	</xs:complexType>
	<!-- CODED_DATA_SECTION -->
	<xs:complexType name="t_coded_data_section">
		<xs:sequence>
			<xs:element ref="REF_OJS"/>
			<xs:element ref="NOTICE_DATA"/>
			<xs:element ref="CODIF_DATA"/>
		</xs:sequence>
	</xs:complexType>
	<xs:element name="CODED_DATA_SECTION" type="t_coded_data_section"/>
	<!--Translation Section -->
	<xs:complexType name="t_translation_section">
		<xs:sequence>
			<xs:element ref="ML_TITLES"/>
			<xs:element ref="ML_AA_NAMES"/>
			<xs:element ref="TRANSLITERATIONS" minOccurs="0"/>
		</xs:sequence>
	</xs:complexType>
	<xs:element name="TRANSLATION_SECTION" type="t_translation_section"/>
	<!-- ###### Definitions used in main sections ######-->
	<!--########################################-->
	<!--t_document_number declaration-->
	<xs:simpleType name="t_document_number">
		<xs:annotation>
			<xs:documentation>Pattern for the Document number (nnnnnn-yyyy - where yyyy = publication year and nnnnnn = document number, with leading zeros)</xs:documentation>
			<xs:documentation>Currently used by DOCUMENT_NUMBER</xs:documentation>
		</xs:annotation>
		<xs:restriction base="xs:string">
			<xs:pattern value="[0-9][0-9]{0,5}\-20[0-9]{2}"/>
		</xs:restriction>
	</xs:simpleType>
	<xs:simpleType name="t_reception_id">
		<xs:annotation>
			<xs:documentation> Pattern for the Reception ID (nn-nnnnnn-nnn)</xs:documentation>
		</xs:annotation>
		<xs:restriction base="xs:string">
			<xs:pattern value="\d{2}-\d{6}-\d{3}"/>
		</xs:restriction>
	</xs:simpleType>
	<xs:element name="COMMENTS" type="btx"/>
	<xs:element name="DELETION_DATE" type="t_simple_date"/>
	<!--t_ref_ojs declaration-->
	<xs:complexType name="t_ref_ojs">
		<xs:sequence>
			<xs:element name="COLL_OJ">
				<xs:annotation>
					<xs:documentation>Restriction for the Type of Journal (x - one char - currently only one value allowed - S = supplement)</xs:documentation>
				</xs:annotation>
				<xs:simpleType>
					<xs:restriction base="xs:string">
						<xs:enumeration value="S"/>
					</xs:restriction>
				</xs:simpleType>
			</xs:element>
			<xs:element name="NO_OJ" type="t_no_oj"/>
			<!-- Publication date -->
			<xs:element name="DATE_PUB" type="t_simple_date"/>
		</xs:sequence>
	</xs:complexType>
	<xs:complexType name="t_no_oj">
		<xs:simpleContent>
			<xs:extension base="no_oj">
				<xs:attribute name="CLASS" default="REGULAR">
					<xs:simpleType>
						<xs:restriction base="xs:string">
							<xs:enumeration value="REGULAR"/>
							<xs:enumeration value="ANNEX"/>
							<xs:enumeration value="ELECTRONIC"/>
						</xs:restriction>
					</xs:simpleType>
				</xs:attribute>
				<xs:attribute name="LAST">
					<xs:simpleType>
						<xs:restriction base="xs:string">
							<xs:enumeration value="YES"/>
						</xs:restriction>
					</xs:simpleType>
				</xs:attribute>
			</xs:extension>
		</xs:simpleContent>
	</xs:complexType>
	<xs:simpleType name="no_oj">
		<xs:annotation>
			<xs:documentation>Pattern for OJ Number (integer - 0 to 999, leading zeros allowed)</xs:documentation>
		</xs:annotation>
		<xs:restriction base="xs:string">
			<xs:pattern value="[0-9]{1,3}"/>
		</xs:restriction>
	</xs:simpleType>
	<xs:element name="REF_OJS" type="t_ref_ojs"/>
	<!--t_notice_data_declaration-->
	<xs:complexType name="t_notice_data">
		<xs:sequence>
			<xs:element ref="NO_DOC_OJS" minOccurs="0"/>
			<xs:element ref="URI_LIST" minOccurs="0"/>
			<xs:element name="LG_ORIG" type="xs:string"/>
			<xs:element name="ISO_COUNTRY" type="country"/>
			<xs:element name="IA_URL_GENERAL" type="xs:string"/>
			<xs:element name="IA_URL_ETENDERING" type="xs:string" minOccurs="0"/>
			<xs:element name="ORIGINAL_CPV" type="t_cpv_code" maxOccurs="unbounded"/>
			<xs:element name="CURRENT_CPV" type="xs:string" minOccurs="0" maxOccurs="unbounded"/>
			<xs:element ref="n2021:PERFORMANCE_NUTS" minOccurs="0" maxOccurs="unbounded"/>
			<xs:element name="CURRENT_NUTS" type="xs:string" minOccurs="0" maxOccurs="unbounded"/>
			<xs:element ref="VALUES_LIST" minOccurs="0"/>
			<xs:element name="REF_NOTICE" type="t_ref_notice" minOccurs="0"/>
		</xs:sequence>
	</xs:complexType>
	<xs:element name="NOTICE_DATA" type="t_notice_data"/>
	<!--values declaration -->
	<xs:element name="VALUES_LIST">
		<xs:complexType>
			<xs:sequence>
				<xs:element ref="VALUES" minOccurs="0" maxOccurs="unbounded"/>
			</xs:sequence>
		</xs:complexType>
	</xs:element>
	<xs:element name="VALUES">
		<xs:complexType>
			<xs:choice>
				<xs:element name="SINGLE_VALUE">
					<xs:complexType>
						<xs:sequence>
							<xs:element name="VALUE" type="t_value"/>
						</xs:sequence>
					</xs:complexType>
				</xs:element>
				<xs:element name="RANGE_VALUE">
					<xs:complexType>
						<xs:sequence>
							<xs:element name="VALUE" type="t_value" maxOccurs="unbounded"/>
						</xs:sequence>
					</xs:complexType>
				</xs:element>
			</xs:choice>
			<xs:attribute name="TYPE">
				<xs:simpleType>
					<xs:restriction base="xs:string">
						<xs:enumeration value="GLOBAL"/>
						<xs:enumeration value="PER_LOT"/>
						<xs:enumeration value="CONTRACT"/>
					</xs:restriction>
				</xs:simpleType>
			</xs:attribute>
		</xs:complexType>
	</xs:element>
	<xs:complexType name="t_value">
		<xs:simpleContent>
			<xs:extension base="xs:string">
				<xs:attribute name="CURRENCY" type="currencies"/>
				<xs:attribute name="FORMAT">
					<xs:simpleType>
						<xs:restriction base="xs:string">
							<xs:enumeration value="NOT_STANDARD"/>
						</xs:restriction>
					</xs:simpleType>
				</xs:attribute>
			</xs:extension>
		</xs:simpleContent>
	</xs:complexType>
	<xs:complexType name="t_directive">
		<xs:annotation>
			<xs:documentation>Directive</xs:documentation>
		</xs:annotation>
		<xs:simpleContent>
			<xs:extension base="xs:string">
				<xs:attribute name="VALUE" use="required">
					<xs:simpleType>
						<xs:restriction base="xs:string">
							<xs:enumeration value="2007/66/EC"/>
							<xs:enumeration value="2004/17/EC"/>
							<xs:enumeration value="2004/18/EC"/>
							<xs:enumeration value="2009/81/EC"/>
							<xs:enumeration value="1370/2007"/>
						</xs:restriction>
					</xs:simpleType>
				</xs:attribute>
			</xs:extension>
		</xs:simpleContent>
	</xs:complexType>
	<!--t_codif_data declaration-->
	<xs:complexType name="t_codif_data">
		<xs:sequence>
			<xs:element name="DS_DATE_DISPATCH" type="t_simple_date"/>
			<xs:element name="DD_DATE_REQUEST_DOCUMENT" type="t_simple_datetime" minOccurs="0"/>
			<xs:element name="DT_DATE_FOR_SUBMISSION" type="t_simple_datetime" minOccurs="0"/>
			<xs:element name="AA_AUTHORITY_TYPE" type="t_autority_type"/>
			<xs:element name="TD_DOCUMENT_TYPE" type="t_document_type"/>
			<xs:element name="NC_CONTRACT_NATURE" type="t_contract_nature"/>
			<xs:element name="PR_PROC" type="t_proc"/>
			<xs:element name="RP_REGULATION" type="t_regulation"/>
			<xs:element name="TY_TYPE_BID" type="t_type_bid"/>
			<xs:element name="AC_AWARD_CRIT" type="t_award_crit"/>
			<xs:element name="MA_MAIN_ACTIVITIES" type="t_main_activities" minOccurs="0" maxOccurs="unbounded"/>
			<xs:element name="HEADING" type="xs:string"/>
			<xs:element name="DIRECTIVE" type="t_directive" minOccurs="0"/>
		</xs:sequence>
	</xs:complexType>
	<xs:element name="CODIF_DATA" type="t_codif_data"/>
	<!--#### Declarations of elements used in NOTICE_DATA######-->
	<xs:simpleType name="t_no_doc_ojs">
		<xs:annotation>
			<xs:documentation>Pattern for Notice No (9999/S 999-999999)</xs:documentation>
		</xs:annotation>
		<xs:restriction base="xs:string">
			<xs:pattern value="20\d{2}/S \d{1,3}-\d{6}"/>
		</xs:restriction>
	</xs:simpleType>
	<xs:element name="NO_DOC_OJS" type="t_no_doc_ojs"/>
	<!-- url_prod declaration.-->
	<xs:simpleType name="t_url_prod">
		<xs:annotation>
			<xs:documentation>
				<p>Pattern for URL (enhanced version)</p>
				<p>Unfortunately the pattern string is very complex</p>
			</xs:documentation>
		</xs:annotation>
		<xs:restriction base="xs:string">
			<xs:pattern value="(((http|https)://)?([a-zA-Z]{1}([a-zA-Z0-9\-])*)(\.([a-zA-Z0-9]{1}([a-zA-Z0-9\-])*))*\.[a-zA-Z]{1,10}(:[0-9]{1,5})?(/([a-zA-Z0-9_\-\.%])*)*((#|\?)([a-zA-Z0-9\?\./:;\-&#x26;_=#%$])*)?)?"/>
		</xs:restriction>
	</xs:simpleType>
	<xs:element name="URI_LIST">
		<xs:complexType>
			<xs:sequence>
				<xs:element name="URI_DOC" type="t_uri_doc" maxOccurs="24"/>
			</xs:sequence>
		</xs:complexType>
		<xs:key name="uri_list.lg">
			<xs:selector xpath="*"/>
			<xs:field xpath="@LG"/>
		</xs:key>
	</xs:element>
	<xs:complexType name="t_uri_doc">
		<xs:simpleContent>
			<xs:extension base="xs:string">
				<xs:attribute name="LG" type="languages"/>
			</xs:extension>
		</xs:simpleContent>
	</xs:complexType>
	<!-- cost_prod declaration -->
	<xs:simpleType name="t_cost_prod">
		<xs:annotation>
			<xs:documentation xml:lang="en">
				<p>Pattern for money amounts.</p>
				<p>The decimal dot (.) is a valid separator between integer and fractional digits.</p>
				<p>The fractional digits can be omitted.</p>
				<p>Examples:</p>
				<p>1234456789.01</p>
			</xs:documentation>
		</xs:annotation>
		<xs:restriction base="xs:decimal">
			<xs:minInclusive value="0"/>
			<xs:fractionDigits value="2"/>
		</xs:restriction>
	</xs:simpleType>
	<!-- Currently two different formats of CPV codes are being used -->
	<xs:complexType name="t_cpv_code">
		<xs:annotation>
			<xs:documentation>CPV codes</xs:documentation>
			<xs:documentation>Currently used by ORIGINAL_CPV and CURRENT_CPV</xs:documentation>
		</xs:annotation>
		<xs:simpleContent>
			<xs:extension base="xs:string">
				<xs:attribute name="CODE" type="t_cpv_code_list" use="required"/>
			</xs:extension>
		</xs:simpleContent>
	</xs:complexType>
	<!--t_ declaration-->
	<xs:complexType name="t_ref_notice">
		<xs:sequence>
			<xs:element ref="NO_DOC_OJS" maxOccurs="unbounded"/>
		</xs:sequence>
	</xs:complexType>
	<!--###### declaration of elements belonging to CODIF_DATA ######-->
	<!--t_sector declaration -->
	<xs:complexType name="t_autority_type">
		<xs:annotation>
			<xs:documentation>Awarding Authority. Type of awarding authority</xs:documentation>
		</xs:annotation>
		<xs:simpleContent>
			<xs:extension base="xs:string">
				<xs:attribute name="CODE" use="required">
					<xs:annotation>
						<xs:documentation>Restriction for Awarding Autorithy. Type of awarding authority</xs:documentation>
					</xs:annotation>
					<xs:simpleType>
						<xs:restriction base="xs:string">
							<xs:enumeration value="1"/>
							<xs:enumeration value="2"/>
							<xs:enumeration value="3"/>
							<xs:enumeration value="4"/>
							<xs:enumeration value="5"/>
							<xs:enumeration value="6"/>
							<xs:enumeration value="8"/>
							<xs:enumeration value="9"/>
							<xs:enumeration value="N"/>
							<xs:enumeration value="R"/>
							<xs:enumeration value="Z"/>
						</xs:restriction>
					</xs:simpleType>
				</xs:attribute>
			</xs:extension>
		</xs:simpleContent>
	</xs:complexType>
	<!--t_nat_notice declaration-->
	<xs:complexType name="t_document_type">
		<xs:annotation>
			<xs:documentation>Type of Document</xs:documentation>
		</xs:annotation>
		<xs:simpleContent>
			<xs:extension base="xs:string">
				<xs:attribute name="CODE" use="required">
					<xs:annotation>
						<xs:documentation>Restriction for Type of Document</xs:documentation>
					</xs:annotation>
					<xs:simpleType>
						<xs:restriction base="xs:string">
							<xs:enumeration value="0"/>
							<xs:enumeration value="1"/>
							<xs:enumeration value="2"/>
							<xs:enumeration value="3"/>
							<xs:enumeration value="4"/>
							<xs:enumeration value="5"/>
							<xs:enumeration value="6"/>
							<xs:enumeration value="7"/>
							<xs:enumeration value="8"/>
							<xs:enumeration value="9"/>
							<xs:enumeration value="A"/>
							<xs:enumeration value="B"/>
							<xs:enumeration value="C"/>
							<xs:enumeration value="D"/>
							<xs:enumeration value="E"/>
							<xs:enumeration value="F"/>
							<xs:enumeration value="G"/>
							<xs:enumeration value="H"/>
							<xs:enumeration value="I"/>
							<xs:enumeration value="J"/>
							<xs:enumeration value="K"/>
							<xs:enumeration value="M"/>
							<xs:enumeration value="O"/>
							<xs:enumeration value="P"/>
							<xs:enumeration value="Q"/>
							<xs:enumeration value="R"/>
							<xs:enumeration value="S"/>
							<xs:enumeration value="V"/>
							<xs:enumeration value="Y"/>
						</xs:restriction>
					</xs:simpleType>
				</xs:attribute>
			</xs:extension>
		</xs:simpleContent>
	</xs:complexType>
	<!-- t_market declaration-->
	<xs:complexType name="t_contract_nature">
		<xs:annotation>
			<xs:documentation>Nature of Contract</xs:documentation>
		</xs:annotation>
		<xs:simpleContent>
			<xs:extension base="xs:string">
				<xs:attribute name="CODE" use="required">
					<xs:annotation>
						<xs:documentation>Restriction for Nature of Contract</xs:documentation>
					</xs:annotation>
					<xs:simpleType>
						<xs:restriction base="xs:string">
							<xs:enumeration value="1"/>
							<xs:enumeration value="2"/>
							<xs:enumeration value="3"/>
							<xs:enumeration value="4"/>
							<xs:enumeration value="9"/>
							<xs:enumeration value="Z"/>
						</xs:restriction>
					</xs:simpleType>
				</xs:attribute>
			</xs:extension>
		</xs:simpleContent>
	</xs:complexType>
	<!--t_proc declaration-->
	<xs:complexType name="t_proc">
		<xs:annotation>
			<xs:documentation>Type of Procedure</xs:documentation>
		</xs:annotation>
		<xs:simpleContent>
			<xs:extension base="xs:string">
				<xs:attribute name="CODE" use="required">
					<xs:annotation>
						<xs:documentation>Restriction for Type of Procedure</xs:documentation>
					</xs:annotation>
					<xs:simpleType>
						<xs:restriction base="xs:string">
							<xs:enumeration value="1"/>
							<xs:enumeration value="2"/>
							<xs:enumeration value="3"/>
							<xs:enumeration value="4"/>
							<xs:enumeration value="5"/>
							<xs:enumeration value="6"/>
							<xs:enumeration value="7"/>
							<xs:enumeration value="8"/>
							<xs:enumeration value="9"/>
							<xs:enumeration value="A"/>
							<xs:enumeration value="B"/>
							<xs:enumeration value="C"/>
							<xs:enumeration value="E"/>
							<xs:enumeration value="F"/>
							<xs:enumeration value="G"/>
							<xs:enumeration value="T"/>
							<xs:enumeration value="V"/>
							<xs:enumeration value="Z"/>
						</xs:restriction>
					</xs:simpleType>
				</xs:attribute>
			</xs:extension>
		</xs:simpleContent>
	</xs:complexType>
	<!--t_market_org-->
	<xs:complexType name="t_regulation">
		<xs:annotation>
			<xs:documentation>Regulation of Procurement</xs:documentation>
		</xs:annotation>
		<xs:simpleContent>
			<xs:extension base="xs:string">
				<xs:attribute name="CODE" use="required">
					<xs:annotation>
						<xs:documentation>Restriction for Regulation of Procurement</xs:documentation>
					</xs:annotation>
					<xs:simpleType>
						<xs:restriction base="xs:string">
							<xs:enumeration value="0"/>
							<xs:enumeration value="1"/>
							<xs:enumeration value="2"/>
							<xs:enumeration value="3"/>
							<xs:enumeration value="4"/>
							<xs:enumeration value="5"/>
							<xs:enumeration value="6"/>
							<xs:enumeration value="7"/>
							<xs:enumeration value="8"/>
							<xs:enumeration value="9"/>
							<xs:enumeration value="A"/>
							<xs:enumeration value="B"/>
							<xs:enumeration value="C"/>
							<xs:enumeration value="S"/>
							<xs:enumeration value="Z"/>
						</xs:restriction>
					</xs:simpleType>
				</xs:attribute>
			</xs:extension>
		</xs:simpleContent>
	</xs:complexType>
	<!-- t_type_bid -->
	<xs:complexType name="t_type_bid">
		<xs:annotation>
			<xs:documentation>Type of bid</xs:documentation>
		</xs:annotation>
		<xs:simpleContent>
			<xs:extension base="xs:string">
				<xs:attribute name="CODE" use="required">
					<xs:annotation>
						<xs:documentation>Restriction for Type of bid</xs:documentation>
					</xs:annotation>
					<xs:simpleType>
						<xs:restriction base="xs:string">
							<xs:enumeration value="1"/>
							<xs:enumeration value="2"/>
							<xs:enumeration value="3"/>
							<xs:enumeration value="8"/>
							<xs:enumeration value="9"/>
							<xs:enumeration value="Z"/>
						</xs:restriction>
					</xs:simpleType>
				</xs:attribute>
			</xs:extension>
		</xs:simpleContent>
	</xs:complexType>
	<!-- t_award_crit -->
	<xs:complexType name="t_award_crit">
		<xs:annotation>
			<xs:documentation>Awarding Criteria</xs:documentation>
		</xs:annotation>
		<xs:simpleContent>
			<xs:extension base="xs:string">
				<xs:attribute name="CODE" use="required">
					<xs:annotation>
						<xs:documentation>Restriction for Awarding Criteria</xs:documentation>
					</xs:annotation>
					<xs:simpleType>
						<xs:restriction base="xs:string">
							<xs:enumeration value="1"/>
							<xs:enumeration value="2"/>
							<xs:enumeration value="3"/>
							<xs:enumeration value="8"/>
							<xs:enumeration value="9"/>
							<xs:enumeration value="Z"/>
						</xs:restriction>
					</xs:simpleType>
				</xs:attribute>
			</xs:extension>
		</xs:simpleContent>
	</xs:complexType>
	<!-- t_main_activities declaration-->
	<xs:complexType name="t_main_activities">
		<xs:annotation>
			<xs:documentation>Main Activities</xs:documentation>
		</xs:annotation>
		<xs:simpleContent>
			<xs:extension base="xs:string">
				<xs:attribute name="CODE" use="required">
					<xs:annotation>
						<xs:documentation>Restriction for Main Activities</xs:documentation>
					</xs:annotation>
					<xs:simpleType>
						<xs:restriction base="xs:string">
							<xs:enumeration value="A"/>
							<xs:enumeration value="B"/>
							<xs:enumeration value="C"/>
							<xs:enumeration value="D"/>
							<xs:enumeration value="E"/>
							<xs:enumeration value="F"/>
							<xs:enumeration value="G"/>
							<xs:enumeration value="H"/>
							<xs:enumeration value="I"/>
							<xs:enumeration value="J"/>
							<xs:enumeration value="K"/>
							<xs:enumeration value="L"/>
							<xs:enumeration value="M"/>
							<xs:enumeration value="N"/>
							<xs:enumeration value="P"/>
							<xs:enumeration value="R"/>
							<xs:enumeration value="S"/>
							<xs:enumeration value="T"/>
							<xs:enumeration value="U"/>
							<xs:enumeration value="W"/>
							<xs:enumeration value="Z"/>
							<xs:enumeration value="8"/>
							<xs:enumeration value="9"/>
						</xs:restriction>
					</xs:simpleType>
				</xs:attribute>
			</xs:extension>
		</xs:simpleContent>
	</xs:complexType>
	<!-- Currently different formats of date are being used -->
	<xs:simpleType name="t_simple_date">
		<xs:annotation>
			<xs:documentation>Pattern for Dispatch and Receipt date (yyyymmdd -- where yyyy = year, mm = month, dd = day)</xs:documentation>
			<xs:documentation>Currently used by DATE_DISP</xs:documentation>
		</xs:annotation>
		<xs:restriction base="xs:string">
			<xs:pattern value="20[0-9]{2}(1[0-2]|0[1-9])((3[0-1])|([1-2][0-9])|(0[1-9]))"/>
		</xs:restriction>
	</xs:simpleType>
	<!-- Currently many different formats of date are being used -->
	<xs:simpleType name="t_simple_datetime">
		<xs:annotation>
			<xs:documentation>Pattern for the Deadline for Specifications and for the Deadline for Applications/Offers (yyyymmdd[ hh:mm] -- where yyyy = year, mm = month, dd = day, hh = hour, mm=minute)</xs:documentation>
			<xs:documentation>Currently used by DEADLINE_REC and DEADLINE_REQ</xs:documentation>
		</xs:annotation>
		<xs:restriction base="xs:string">
			<xs:pattern value="20[0-9]{2}(1[0-2]|0[1-9])((3[0-1])|([1-2][0-9])|(0[1-9]))( ((2[0-3])|([0-1][0-9])):[0-5][0-9])?"/>
		</xs:restriction>
	</xs:simpleType>
